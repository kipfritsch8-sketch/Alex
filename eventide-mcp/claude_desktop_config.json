{
  "mcpServers": {
    "eventide": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/kipfritsch8-sketch/alex.git#subdirectory=eventide-mcp",
        "eventide-mcp"
      ],
      "env": {
        "EVENTIDE_STATE_FILE": "/Users/你的用户名/.eventide_state.json"
      }
    }
  }
}
